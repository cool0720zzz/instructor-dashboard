{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/admin/auth/:path*", "destination": "/api/auth/:path*" },
    { "source": "/admin/customers/:path*", "destination": "/api/customers/:path*" },
    { "source": "/admin/customers", "destination": "/api/customers/index" },
    { "source": "/admin/instructors/:path*", "destination": "/api/instructors/:path*" },
    { "source": "/((?!api/|admin/).*)", "destination": "/index.html" }
  ]
}
